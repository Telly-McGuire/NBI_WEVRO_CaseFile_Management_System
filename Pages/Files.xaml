<Page
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="CFMS_WPF.Files"
        Title="Files"
        Background="#E6EBF0"
		d:DesignHeight="678.94" d:DesignWidth="1062.71"
		Height="Auto">

	<Grid x:Name="RootGrid">

		<Grid.ColumnDefinitions>
			<ColumnDefinition x:Name="SidebarColumn" Width="0"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- ================= MAIN CONTENT ================= -->
		<Grid Grid.Column="1">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- HEADER -->
			<Border Background="White" Padding="30,20,40,20">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- LEFT -->
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
						<TextBlock Text="Files"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
					</StackPanel>

					<!-- RIGHT -->
					<StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

						<Border Background="#F1F5F9"
								CornerRadius="20"
								Width="240"
								Height="38"
								Margin="0,0,15,0">

							<Grid>
								<TextBlock Text="Search..."
										   Margin="15,0"
										   VerticalAlignment="Center"
										   Foreground="Gray"
										   IsHitTestVisible="False">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Visibility" Value="Collapsed"/>
											<Style.Triggers>
												<DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
													<Setter Property="Visibility" Value="Visible"/>
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>

								<TextBox x:Name="SearchBox"
										 Background="Transparent"
										 BorderThickness="0"
										 Padding="15,0"
										 VerticalContentAlignment="Center"
										 FontSize="13"
										 Foreground="Gray"
										 TextChanged="SearchBox_TextChanged"
										 />

								<!-- Popup for suggestions -->
								<Popup x:Name="SearchPopup"
										   PlacementTarget="{Binding ElementName=SearchBox}"
										   Placement="Bottom"
										   StaysOpen="False">
									<Border Background="White" CornerRadius="5" BorderBrush="Gray" BorderThickness="1">
										<ListBox x:Name="SearchSuggestions"
													MouseLeftButtonUp="SearchSuggestions_MouseLeftButtonUp"
													Width="240"/>
									</Border>
								</Popup>
							</Grid>
						</Border>

					</StackPanel>
				</Grid>
			</Border>

			<!-- BODY -->
			<ScrollViewer Grid.Row="1">
				<StackPanel Margin="50">

					<!-- ================= ALL FILES HEADER ================= -->
					<Grid Margin="0,0,0,15">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Orientation="Horizontal">

							<TextBlock Text="All Files"
									   FontSize="18"
									   FontWeight="SemiBold"
									   VerticalAlignment="Center"/>

						</StackPanel>

						<!-- Right Side Buttons -->
						<StackPanel Grid.Column="1"
									Orientation="Horizontal"
									HorizontalAlignment="Right"
									VerticalAlignment="Center">

							<Button x:Name="btn_FilesRefresh"
									Width="110"
									Height="40"
									Background="White"
									Foreground="#1F2937"
									FontWeight="SemiBold"
									BorderThickness="0"
									Click="RefreshButton_Click"
									AutomationProperties.Name="btnRefresh"
									Margin="10,0,10,0">

								<Button.Template>
									<ControlTemplate TargetType="{x:Type Button}">
										<Border Background="{TemplateBinding Background}"
							                    CornerRadius="20">
											<StackPanel Orientation="Horizontal"
														HorizontalAlignment="Center"
														VerticalAlignment="Center"
														Margin="5,0,5,0">
												<!-- Rotating Arrow Path -->
												<Path Data="M12,4V1L8,5l4,4V6a6,6 0 1,1-6,6H4a8,8 0 1,0 8-8z"
													  Fill="#1F2937"
													  Width="16"
													  Height="16"
													  Stretch="Uniform"
													  Margin="0,0,5,0"/>
												<!-- Text -->
												<TextBlock Text="Refresh"/>
											</StackPanel>
										</Border>
									</ControlTemplate>
								</Button.Template>
							</Button>

							<!-- FILTER BUTTON -->
							<Button x:Name="FilterButton"
									Width="110"
									Height="40"
									Background="White"
									Foreground="#1F2937"
									FontWeight="SemiBold"
									BorderThickness="0"
									Margin="0,0,10,0"
									Click="FilterButton_Click" AutomationProperties.Name="btnFilter">

								<Button.Template>
									<ControlTemplate TargetType="{x:Type Button}">
										<Border Background="{TemplateBinding Background}"
												CornerRadius="20">
											<ContentPresenter HorizontalAlignment="Center"
															  VerticalAlignment="Center"/>
										</Border>
									</ControlTemplate>
								</Button.Template>

								<TextBlock Text="Filter"/>
							</Button>

							<Button x:Name="btnAddFile" Width="140"
									Height="40"
									Click="File_UploadClick"
									Background="#4A6FA5"
									Foreground="White"
									FontWeight="SemiBold"
									BorderThickness="0" AutomationProperties.Name="btnAddFile">

								<Button.Template>
									<ControlTemplate TargetType="{x:Type Button}">
										<Border Background="{TemplateBinding Background}"
												CornerRadius="20">
											<ContentPresenter HorizontalAlignment="Center"
															  VerticalAlignment="Center"/>
										</Border>
									</ControlTemplate>
								</Button.Template>

								<StackPanel Orientation="Horizontal"
											HorizontalAlignment="Center"
											VerticalAlignment="Center">

									<Path Data="M10,0 L14,0 L14,10 L24,10 L24,14 L14,14 L14,24 L10,24 L10,14 L0,14 L0,10 L10,10 Z"
										  Fill="White"
										  Width="14"
										  Height="14"
										  Stretch="Uniform"
										  Margin="0,0,8,0"/>

									<TextBlock
											   VerticalAlignment="Center" Text="Uplod File"/>
								</StackPanel>

							</Button>

							<!-- ADD FILE BUTTON -->

						</StackPanel>
						<!-- Right Side Buttons -->
					</Grid>
					<!-- ================= ICON VIEW (ALL FILES) ================= -->
					<WrapPanel x:Name="IconViewPanel"
							   Margin="0,10,0,0"
							   Visibility="Collapsed">

						<!-- Sample Card -->
						<Border Width="160"
								Height="150"
								Background="White"
								CornerRadius="20"
								Margin="10"
								Padding="15">

							<StackPanel VerticalAlignment="Center"
										HorizontalAlignment="Center">

								<Path Data="M10,0 L60,0 L60,80 L10,80 Z"
									  Fill="#4A6FA5"
									  Width="45"
									  Height="55"
									  Stretch="Uniform"/>

								<TextBlock Text="2026-C-030.pdf"
										   Margin="0,15,0,5"
										   FontSize="13"
										   FontWeight="SemiBold"
										   HorizontalAlignment="Center"/>

								<TextBlock Text="Open"
										   FontSize="11"
										   Foreground="Gray"
										   HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

					</WrapPanel>

					<!-- ================= LIST VIEW ================= -->
					<Border x:Name="ListViewPanel"
							Margin="0,10,0,0"
							Background="White"
							CornerRadius="15"
							Padding="20"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch">

						<DataGrid x:Name="dataFiles"
								  AutoGenerateColumns="False"
								  HeadersVisibility="Column"
								  RowHeight="40"
								  CanUserAddRows="False"
								  CanUserReorderColumns="False" 
								  AutomationProperties.Name="dataViewFiles" 
								  HorizontalGridLinesBrush="Black" 
								  SelectionChanged="FilesDataGrid_SelectionChanged" 
								  Background="White"
								  HorizontalAlignment="Stretch"
								  VerticalAlignment="Stretch"
								  IsReadOnly="True">

							<DataGrid.Resources>
								<Style TargetType="DataGridCell">
									<Setter Property="Margin" Value="5,0,5,0"/>
									<Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
									<Setter Property="VerticalAlignment" Value="Top"/>
									<!-- left/right margin -->
								</Style>
							</DataGrid.Resources>

							<DataGrid.Columns>

								<DataGridTextColumn Header="Case Type" Binding="{Binding caseType}" Width="*"/>
								<DataGridTextColumn Header="Year" Binding="{Binding caseYear}" Width="*"/>
								<DataGridTextColumn Header="Case No." Binding="{Binding caseNo}" Width="*"/>
								<DataGridTextColumn Header="Subject" Binding="{Binding caseSubject}" Width="*"/>
								<DataGridTextColumn Header="Nature Of Case" Binding="{Binding caseNature}" Width="*">
									<DataGridTextColumn.ElementStyle>
										<Style TargetType="TextBlock">
											<Setter Property="TextWrapping" Value="Wrap"/>
										</Style>
									</DataGridTextColumn.ElementStyle>
								</DataGridTextColumn>
								<DataGridTextColumn Header="Complainant" Binding="{Binding caseComplainant}" Width="*"/>
								<DataGridTextColumn Header="Agent Name" Binding="{Binding caseAgent}" Width="*"/>
								<DataGridTextColumn Header="Status" Binding="{Binding caseStatus}" Width="*"/>

								<!-- ACTION COLUMN MUST BE INSIDE -->
								<DataGridTemplateColumn Header="Action" Width="*">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel Orientation="Horizontal">

												<Button Content="View File"
														Click="ViewFile_Click"
														Width="60"
														Height="30"
														Margin="0,0,10,5"
														Background="#4A6FA5"
														Foreground="White"
														BorderThickness="0"/>

												<Button Content="Edit"
														Click="EditFile_Click"
														Width="60"
														Height="30"
														Margin="0,0,0,5"
														Background="#4A6FA5"
														Foreground="White"
														BorderThickness="0"
														HorizontalContentAlignment="Center"
														VerticalContentAlignment="Center"/>

											</StackPanel>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
							</DataGrid.Columns>
						</DataGrid>
					</Border>


					<Grid Margin="10">
						<StackPanel  Margin =" 5"
								Orientation="Horizontal">

							<TextBlock Text=""
									   FontSize="18"
									   FontWeight="SemiBold"
									   VerticalAlignment="Center"/>

						</StackPanel>
						<StackPanel Orientation="Horizontal"
									HorizontalAlignment="Right">

						</StackPanel>

					</Grid>
				</StackPanel>
			</ScrollViewer>
		</Grid>
	</Grid>
</Page>