<Window x:Class="CFMS_WPF.FilterPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Files"
        Height="425"
        Width="350"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Background="#F1F3F6">

	<Border Padding="25">

		<StackPanel>

			<!-- YEAR -->
			<TextBlock Text="Year"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

			<ComboBox x:Name="YearComboBox"
                      Height="35"
                      Margin="0,0,0,15"
                      IsEditable="False"
                      Padding="10" SelectionChanged="YearComboBox_SelectionChanged"/>

			<!-- CASE TYPE -->
			<TextBlock Text="Case Type"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

			<ComboBox x:Name="CaseTypeComboBox"
                      Height="35"
                      Margin="0,0,0,15"
                      Padding="10" SelectionChanged="CaseTypeComboBox_SelectionChanged">
			</ComboBox>

			<!-- CASE NO -->
			<TextBlock Text="Case No."
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

			<TextBox   x:Name="txt_FilterCaseNo"
                       Text="Case Number..."
                       Height="35"
                       Margin="0,0,0,5"
                       Padding="10" TextChanged="txt_FilterCaseNo_TextChanged"/>

			<!-- AGENT NAME -->
			<TextBlock Text="Agent Name"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>

			<ComboBox x:Name="AgentNameComboBox"
                      Height="35"
                      Margin="0,0,0,20"
                      IsEditable="False"
                      IsTextSearchEnabled="True"
                      Padding="10" SelectionChanged="AgentNameComboBox_SelectionChanged_1"/>

			<!-- BUTTONS -->
			<StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

				<Button Content="Cancel"
                        Width="80"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>

				<Button Content="Apply"
                        Width="80"
                        Height="35"
                        Background="#4A6FA5"
                        Foreground="White"
                        Click="Apply_Click"/>
			</StackPanel>

		</StackPanel>

	</Border>
</Window>