<Window x:Class="CFMS_WPF.AddAgentPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Agent"
        Background="#F3F4F6" >

	<Grid Margin="40">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- HEADER -->
		<TextBlock Text="Agents"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,25"/>

		<!-- MAIN CONTENT -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="2*"/>
				<ColumnDefinition Width="1*"/>
			</Grid.ColumnDefinitions>

			<!-- ================= LEFT SIDE - AGENT TABLE ================= -->
			<Border Margin="0,0,25,0"
							Background="White"
							CornerRadius="15"
							Padding="20">

				<DataGrid x:Name="data_AgentInfo"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          RowHeight="45"
                          CanUserAddRows="False"
                          Background="White"
                          BorderThickness="0" SelectionChanged="data_AgentInfo_SelectionChanged">

					<DataGrid.Columns>
						<DataGridTextColumn Header="Agent ID" Binding="{Binding agentID}" Width="*"/>
						<DataGridTextColumn Header="Last Name" Binding="{Binding agentlastName}" Width="*"/>
						<DataGridTextColumn Header="First Name" Binding="{Binding agentfirstName}" Width="*"/>
						<DataGridTextColumn Header="Middle Initial" Binding="{Binding agentMiddleInitial}" Width="*"/>
					</DataGrid.Columns>
				</DataGrid>
			</Border>

			<Border Grid.Column="1">

				<StackPanel>

					<TextBlock Text="Agent Id" FontWeight="SemiBold" Margin="0,0,0,4"/>
					<TextBox x:Name="txt_AgentId" Tag="Agent ID"
					Margin="0,0,0,20" TextChanged="LastNameBox_TextChanged"
					IsReadOnly="True"/>

					<!-- LAST NAME -->
					<TextBlock Text="Last Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
					<TextBox x:Name="txt_AgentLastName"
                 Tag="Last Name"
                 Margin="0,0,0,20" TextChanged="LastNameBox_TextChanged"/>

					<!-- FIRST NAME -->
					<TextBlock Text="First Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
					<TextBox x:Name="txt_AgentFirstName"

                 Tag="First Name"
                 Margin="0,0,0,20" TextChanged="txt_AgentFirstName_TextChanged"/>

					<!-- MIDDLE INITIAL -->
					<TextBlock Text="Middle Initial" FontWeight="SemiBold" Margin="0,0,0,4"/>
					<TextBox x:Name="txt_AgentMI"
                 Tag="Middle Initial"
                 Width="50"
                 HorizontalAlignment="Left"
                 MaxLength="1"
                 Margin="0,0,0,40"
                 TextChanged="MiddleInitialBox_TextChanged"/>

					<Rectangle Height="Auto" VerticalAlignment="Stretch"/>
					<StackPanel Width="373" Height="170" Margin="0,0,0,0">

						<Button x:Name="btn_AddAgent"
								Content="Add"
								Height="30"
								Width="200"
								Background="#3F72AF"
								Foreground="White"
								Click="AddAgent_Click"
								Margin="0,0,0,10">		
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
											CornerRadius="5"
											BorderBrush="{TemplateBinding BorderBrush}"
											BorderThickness="{TemplateBinding BorderThickness}">
										<ContentPresenter HorizontalAlignment="Center"
															VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>

						<Button x:Name="btn_SaveAgent"
									Content="Save"
									Height="30"
									Width="200"
									Background="#FF3F72AF" 
									BorderBrush="{x:Null}" 
									Foreground="White" 
									Click="btn_SaveAgent_Click"
									Margin="0,0,0,10">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
										CornerRadius="5"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}">
										<ContentPresenter HorizontalAlignment="Center"
														VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>

						<Button x:Name="btn_ClearAgent"
									Content="Clear"
									Height="30"
									Width="200"
									Background="#FF3F72AF" 
									BorderBrush="{x:Null}" 
									Foreground="White" 
									Click="btn_ClearAgent_Click"
									Margin="0,0,0,10">
							<Button.Template>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
										CornerRadius="5"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}">
										<ContentPresenter HorizontalAlignment="Center"
														VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Button.Template>
						</Button>
					</StackPanel>

				</StackPanel>
			</Border>

		</Grid>

	</Grid>

</Window>