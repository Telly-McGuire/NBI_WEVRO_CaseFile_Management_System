<Window x:Class="CFMS_WPF.AddFile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add File"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#EDE7EF"
        ResizeMode="NoResize">

	<Window.Resources>

		<!-- Rounded Button Style -->
		<Style TargetType="Button">
			<Setter Property="Height" Value="44"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Padding" Value="18,6"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Grid>

		<!-- Outer Card -->
		<Border Margin="25"
                Background="White"
                CornerRadius="20"
                BorderBrush="#D6D6D6"
                BorderThickness="1">

			<Grid>

				<Grid.RowDefinitions>
					<RowDefinition Height="70"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="90"/>
				</Grid.RowDefinitions>

				<!-- Header -->
				<Border Background="#E6DDEA"
                        CornerRadius="20,20,0,0">
					<StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0">

						<TextBlock Text="Files"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
					</StackPanel>
				</Border>

				<!-- Upload Area -->
				<Grid Grid.Row="1" Margin="90,50">

					<Border x:Name="DropZone"
                            AllowDrop="True"
                            DragEnter="DropZone_DragEnter"
                            Drop="DropZone_Drop"
                            CornerRadius="18"
                            Background="#F8F8F8"
                            BorderThickness="2">

						<!-- Dashed Border -->
						<Border.BorderBrush>
							<VisualBrush TileMode="Tile"
                                         Viewport="0,0,6,6"
                                         ViewportUnits="Absolute"
                                         Viewbox="0,0,6,6"
                                         ViewboxUnits="Absolute">
								<VisualBrush.Visual>
									<Rectangle Width="3"
                                               Height="3"
                                               Fill="#C9C9C9"/>
								</VisualBrush.Visual>
							</VisualBrush>
						</Border.BorderBrush>

						<StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">

							<TextBlock Text="☁"
                                       FontSize="54"
                                       Foreground="#9E9E9E"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

							<TextBlock Text="Select a file or drag and drop here"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>

							<TextBlock Text="JPG, PNG or PDF, file size no more than 10MB"
                                       FontSize="14"
                                       Foreground="#8C8C8C"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,15"/>

							<Button Content="SELECT FILE"
                                    Width="150"
                                    Height="38"
                                    Click="SelectFile_Click"
                                    Background="White"
                                    BorderBrush="#42A5F5"
                                    Foreground="#42A5F5"
                                    FontWeight="SemiBold"/>
						</StackPanel>


					</Border>
				</Grid>

				<!-- Bottom Buttons -->
				<Border Grid.Row="2"
                        Background="#F5F5F5"
                        CornerRadius="0,0,20,20">

					<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,40,0">

						<Button Content="Cancel"
                                Width="120"
                                Background="#E0E0E0"
                                Foreground="#333"
                                Margin="0,0,15,0"
                                Click="Cancel_Click"/>

						<Button x:Name="UploadButton"
                                Content="Upload"
                                Width="120"
                                Background="#4A6FA5"
                                Foreground="White"
                                Margin="0,0,15,0"
                                IsEnabled="False"
                                Click="Upload_Click"/>
					</StackPanel>
				</Border>
			</Grid>
		</Border>
	</Grid>
</Window>