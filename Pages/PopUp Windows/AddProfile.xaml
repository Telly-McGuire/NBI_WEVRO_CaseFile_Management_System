<Window x:Class="CFMS_WPF.Pages.PopUp_Windows.AddProfile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AddProfile"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#E9EEF2">

	<Grid>

		<!-- Center Card -->
		<Border Background="#F3F6F8"
                CornerRadius="20"
                BorderBrush="#D6D6D6"
                BorderThickness="1"
                Padding="30"
                Margin="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

			<StackPanel>

				<!-- Header -->
				<StackPanel Orientation="Horizontal" Margin="0,0,0,20">
					<Image Source="\Images\NBI WEVRO LOGO 2026.png"
                           Width="70"
                           Height="70"
                           Margin="0,0,15,0"/>

					<TextBlock Text="New Profile"
                               FontSize="32"
                               FontWeight="DemiBold"
                               VerticalAlignment="Center"/>
				</StackPanel>

				<!-- FORM GRID -->
				<Grid Margin="0,10,0,20">

					<!-- Columns -->
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="200"/>
						<ColumnDefinition Width="420"/>
					</Grid.ColumnDefinitions>

					<!-- Rows -->
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<!-- Username -->
					<TextBlock Text="Username:"
                               Grid.Row="0" Grid.Column="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,15,15"/>

					<Border Grid.Row="0" Grid.Column="1"
                            Height="50"
                            Background="#ECECEC"
                            CornerRadius="15"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Margin="0,0,0,15">

						<TextBox x:Name="txt_AddProfileUser"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="18"
                                 Padding="15,0"
                                 VerticalContentAlignment="Center"/>
					</Border>

					<!-- Full Name -->
					<TextBlock Text="Full Name:"
                               Grid.Row="1" Grid.Column="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,15,15"/>

					<Border Grid.Row="1" Grid.Column="1"
                            Height="50"
                            Background="#ECECEC"
                            CornerRadius="15"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Margin="0,0,0,15">

						<TextBox x:Name="txt_AddProfileName"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="18"
                                 Padding="15,0"
                                 VerticalContentAlignment="Center"/>
					</Border>

					<!-- Role -->
					<TextBlock Text="Position:"
                               Grid.Row="2" Grid.Column="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,15,15"/>

					<Border Grid.Row="2" Grid.Column="1"
                            Height="50"
                            Background="#ECECEC"
                            CornerRadius="15"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Margin="0,0,0,15">

						<TextBox x:Name="txt_AddProfileRole"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="18"
                                 Padding="15,0"
                                 Text="Encoder"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True"/>
					</Border>

					<!-- Section Title -->
					<TextBlock Text="Set Password"
                               Grid.Row="3"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,10"/>

					<!-- New Password -->
					<TextBlock Text="New Password:"
                               Grid.Row="4" Grid.Column="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,15,15"/>

					<Border Grid.Row="4" Grid.Column="1"
                            Height="50"
                            Background="#ECECEC"
                            CornerRadius="15"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Margin="0,0,0,15">

						<PasswordBox x:Name="Add_NewPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"/>
					</Border>

					<!-- Confirm Password -->
					<TextBlock Text="Confirm Password:"
                               Grid.Row="5" Grid.Column="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>

					<Border Grid.Row="5" Grid.Column="1"
                            Height="50"
                            Background="#ECECEC"
                            CornerRadius="15"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1">

						<PasswordBox x:Name="Add_ConfirmPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="18"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"/>
					</Border>

				</Grid>

				<!-- Button -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

					<Button Content="Cancel"
                        Width="200"
                        Height="50"
                        Background="#FFC1C1C1"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        Click="Cancel_Click"
                        Margin="0,0,20,0">

						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}"
                                    CornerRadius="12">
									<ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
								</Border>
							</ControlTemplate>
						</Button.Template>

					</Button>

					<Button Content="Add Profile"
                        Width="200"
                        Height="50"
                        Background="#4A6FA5"
                        Foreground="White"
                        FontSize="18"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        Click="AddProfile_Click">

						<Button.Template>
							<ControlTemplate TargetType="Button">
								<Border Background="{TemplateBinding Background}"
                                    CornerRadius="12">
									<ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
								</Border>
							</ControlTemplate>
						</Button.Template>

					</Button>

				</StackPanel>
			</StackPanel>
		</Border>

	</Grid>
</Window>