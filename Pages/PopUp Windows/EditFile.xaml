<Window x:Class="CFMS_WPF.EditFile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Edit File"
        WindowStartupLocation="CenterScreen"
		WindowState="Maximized"
        Background="#F5F6FA">

	<Window.Resources>

		<!-- TEXTBOX STYLE (smaller + aligned) -->
		<Style TargetType="TextBox">
			<Setter Property="Height" Value="34"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="8,3"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Background" Value="#F9FAFB"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
							<ScrollViewer x:Name="PART_ContentHost"
                                      Margin="6,0"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- COMBOBOX STYLE -->
		<Style TargetType="ComboBox">
			<Setter Property="Height" Value="34"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="6"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<!-- BUTTON STYLE -->
		<Style TargetType="Button">
			<Setter Property="Height" Value="34"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Padding" Value="12,4"/>
			<Setter Property="Margin" Value="6"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Grid Margin="30">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="2*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>

		<!-- LEFT SIDE - PDF PREVIEW -->
		<Border Background="White"
                CornerRadius="15"
                Padding="20"
                Margin="0,0,20,0">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- PDF Viewer -->
				<wv2:WebView2 x:Name="PdfViewer"
							  Grid.Row="0"/>

				<!-- Page Navigation -->
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0"
                            Grid.Row="1">

					<Button Content="← Previous"
                            Click="PreviousPage_Click"
                            Margin="10"/>

					<TextBlock x:Name="PageIndicator"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>

					<Button Content="Next →"
                            Click="NextPage_Click"
                            Margin="10"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- RIGHT SIDE - FILE DETAILS -->
		<Border Grid.Column="1"
                Background="White"
                CornerRadius="15"
                Padding="25">

			<StackPanel>

				<TextBlock Text="File Name"
                           FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<TextBox x:Name="txt_EditFileName"
						 TextChanged="FileNameBox_TextChanged"
						 Margin="0,0,0,12" SelectionTextBrush="White" Cursor="Arrow" IsReadOnly="True"/>

				<TextBlock x:Name="txt_UploadcaseType" Text="Case Type"
						   FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<ComboBox x:Name="Edit_CaseTypeComboBox"
						  Margin="0,0,0,12" SelectionChanged="Upload_CaseTypeBox_SelectionChanged">
				</ComboBox>

				<TextBlock x:Name="asgdafsg" Text="Year"
						   FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<TextBox x:Name="txt_EditYear"
						 MaxLength="4"
						 PreviewTextInput="YearBox_PreviewTextInput"
						 DataObject.Pasting="YearBox_Pasting"
						 TextChanged="EditYear_Changed"
						 Margin="0,0,0,12" RenderTransformOrigin="1.788,492493774.74"/>

				<TextBlock x:Name="saddfa" Text="Case Number"
						   FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<TextBox x:Name="txt_EditCaseNo"
						 Margin="0,0,0,12" TextChanged="txt_EditCaseNo_TextChanged"/>

				<TextBlock x:Name="afsdafas" Text="Subject"
						   FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<TextBox x:Name="txt_EditSubject"
						 TextChanged="txt_EditCaseSubject_Changed"
						 Margin="0,0,0,12"/>

				<TextBlock x:Name="txt_Uadsfafga" Text="Nature of Case"
						   FontWeight="SemiBold"
						   Margin="0,0,0,0"/>
				<TextBlock x:Name="txt_Uads" Text="(All Caps)"
						   FontWeight="Light"
						   Margin="0,0,0,4"/>
				<TextBox x:Name="txt_EditNature"
						   TextChanged="txt_EditNature_Changed"
						   Height="160"
						   Margin="0,0,0,12"
						   AcceptsReturn="True"
						   TextWrapping="Wrap"
						   VerticalScrollBarVisibility="Auto"/>

				<!-- NEW: Complainants -->
				<TextBlock x:Name="txt_UploadCaseComplainant" Text="Complainants"
						   FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<TextBox x:Name="txt_EditComplainants" TextChanged="txt_EditComplainants_TextChanged"
						 />
				<CheckBox x:Name="Edit_MultipleComplainantsCheckBox"
						  Content="Multiple Complainants (add et al.)"
						  Margin="0,0,0,12"
						  FontSize="12"
						  Checked="Edit_MultipleComplainantsCheckBox_Checked"
						  Unchecked="Edit_MultipleComplainantsCheckBox_UnChecked"/>


				<TextBlock x:Name="txt_UploadAgentName" Text="Agent Name"
							FontWeight="SemiBold"
							Margin="0,0,0,4"/>
				<ComboBox x:Name="Edit_AgentNameComboBox"
						 Margin="0,0,0,0" SelectionChanged="Edit_AgentNameComboBox_SelectionChanged" />
				<Button Content="Add Agent"
						HorizontalAlignment="Left"
                        Width="64"
						FontSize="5"
                        Click="AddAgent_Click" Height="15"/>

				<TextBlock x:Name="txt_UploadStatus" Text="Status"
						   FontWeight="SemiBold"
						   Margin="0,0,0,4"/>
				<ComboBox x:Name="Edit_StatusComboBox"
                          Margin="0,0,0,12" SelectionChanged="Edit_StatusComboBox_SelectionChanged"/>

				<StackPanel Margin="0,10,0,15">

					<StackPanel Orientation="Horizontal" Margin="0,0,0,15">
						<TextBlock Text="User: "
								   FontWeight="SemiBold"
								   Foreground="#777777"/>
						<TextBox x:Name="UsernameText"
								   Foreground="#777777" IsReadOnly="True" Width="190" />
					</StackPanel>

					<StackPanel Orientation="Horizontal">
						<TextBlock Text="Upload Date: "
								   FontWeight="SemiBold"
								   Foreground="#777777"/>
						<TextBox x:Name="UploadDateText"
								   Foreground="#777777" IsReadOnly="True" Width="150" />
					</StackPanel>

				</StackPanel>

				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

					<Button Content="Cancel"
                            Width="90"
                            Margin="10"
                            Click="Cancel_Click"/>

					<Button Content="Save"
                            Width="100"
                            Background="#3F72AF"
                            Foreground="White"
                            Click="Save_Click"/>
				</StackPanel>

			</StackPanel>
		</Border>

	</Grid>
</Window>