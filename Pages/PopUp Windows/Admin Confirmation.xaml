<Window x:Class="CFMS_WPF.Pages.PopUp_Windows.Admin_Confirmation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CFMS_WPF.Pages.PopUp_Windows"
        mc:Ignorable="d"
        Title="Admin_Confirmation"        
        Height="350"
        Width="700"
        Background="#E6E1E7">
	<Grid>
		<StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420">

			<!-- TITLE -->
			<TextBlock Text="Admin Confirmation Needed!"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

			<!-- USERNAME -->
			<Border Background="#F2F2F2"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,0,15">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- User Icon -->
					<TextBlock Text="👤"
                               VerticalAlignment="Center"
                               Margin="5,0,10,0"/>

					<!-- Username TextBox -->
					<TextBox x:Name="Confirm_UsernameBox"
                             Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="16"
                             VerticalContentAlignment="Center"/>

					<!-- Empty column to match password layout -->
					<Border Grid.Column="2"
                            Width="35"
                            Background="Transparent"/>
				</Grid>

			</Border>

			<!-- PASSWORD -->
			<Border Background="#F2F2F2"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,0,25">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Lock Icon -->
					<TextBlock Text="🔒"
                               VerticalAlignment="Center"
                               Margin="5,0,10,0"/>

					<!-- PasswordBox -->
					<PasswordBox x:Name="Confirm_PasswordBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="16"
                                 VerticalContentAlignment="Center"/>

					<!-- Visible Password -->
					<TextBox x:Name="VisiblePasswordBox"
                             Grid.Column="1"
                             Visibility="Collapsed"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="16"
                             VerticalContentAlignment="Center"/>

					<!-- Eye Button -->
					<Button x:Name="EyeButton"
                            Grid.Column="2"
                            Width="35"
                            Background="Transparent"
                            BorderThickness="0">

						<Path x:Name="EyeIcon"
                              Width="18"
                              Height="18"
                              Stretch="Uniform"
                              Fill="#4B5563"
                              Data="M1 8C1 8 4 3 8 3s7 5 7 5-3 5-7 5-7-5-7-5z
                                    M8 6a2 2 0 1 1 0 4a2 2 0 0 1 0-4z"/>
					</Button>

				</Grid>
			</Border>

			<!-- LOGIN BUTTON -->
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="btn_Login" Content="Confirm"
                        Width="150"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#4E73A8"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,30,0"
                        Click="Confirm_Click"
                        IsDefault="True">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}" CornerRadius="10">
								<ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
							</Border>
						</ControlTemplate>
					</Button.Template>
				</Button>
			</StackPanel>

		</StackPanel>

		<TextBlock VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Margin="0,0,15,10"
                        FontSize="14"
                        IsHitTestVisible="False"
                        Text="{Binding NowPlusTen}" />

	</Grid>
</Window>
