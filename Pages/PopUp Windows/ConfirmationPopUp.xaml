<Window x:Class="CFMS_WPF.ConfirmationPopUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfirmationPopUp" Height="540" Width="900">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Logo row -->
			<RowDefinition Height="*"/>
			<!-- Form row -->
			<RowDefinition Height="Auto"/>
			<!-- Buttons row -->
		</Grid.RowDefinitions>
		<StackPanel Orientation="Horizontal" Margin="8">
			<!-- Logo at left -->
			<Image Source="/Images/NBI WEVRO LOGO 2026.png"
           Height="80"
           Width="80"
           Margin="4"
           VerticalAlignment="Center"/>

			<!-- File Name label -->
			<Label Content="File Name :"
					FontSize="20"
					Margin="8,0"
					VerticalAlignment="Center"/>	

			<!-- File Name textbox -->
			<TextBox x:Name="txt_UploadFinalFileName"
					 FontSize="25"
					 Width="650"
					 Margin="4"
					 VerticalAlignment="Center" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True"/>
		</StackPanel>

		<!-- Form -->
		<Border Grid.Row="1"
                Background="WhiteSmoke"
                CornerRadius="15"
                Padding="0"
                Margin="10,10,10,10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="150"/>
					<!-- Label column -->
					<ColumnDefinition Width="*"/>
					<!-- TextBox column -->
				</Grid.ColumnDefinitions>

				<Grid.RowDefinitions>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
					<RowDefinition Height="35"/>
				</Grid.RowDefinitions>

				<!-- Case Type -->
				<Label Grid.Row="1" Grid.Column="0" Content="Case Type :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalCaseType" Grid.Row="1" Grid.Column="1" Margin="4" BorderBrush="{x:Null}" Background="WhiteSmoke" IsReadOnly="True"/>

				<!-- Year -->
				<Label Grid.Row="2" Grid.Column="0" Content="Year :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalYear" Grid.Row="2" Grid.Column="1" Margin="4" BorderBrush="{x:Null}" Background="WhiteSmoke" IsReadOnly="True"/>

				<!-- Case No. -->
				<Label Grid.Row="3" Grid.Column="0" Content="Case Number :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalCaseNo" Grid.Row="3" Grid.Column="1" Margin="4" BorderBrush="{x:Null}" Background="WhiteSmoke" IsReadOnly="True"/>

				<!-- Complainants -->
				<Label Grid.Row="4" Grid.Column="0" Content="Complainants :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalCaseComplainant" Grid.Row="4" Grid.Column="1" Margin="4" BorderBrush="{x:Null}" Background="WhiteSmoke" IsReadOnly="True"/>

				<!-- Agent Name -->
				<Label Grid.Row="5" Grid.Column="0" Content="Agent Name :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalAgentName" Grid.Row="5" Grid.Column="1" Margin="4" BorderBrush="{x:Null}" Background="WhiteSmoke" IsReadOnly="True"/>

				<!-- Status -->
				<Label Grid.Row="6" Grid.Column="0" Content="Status :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalStatus" Grid.Row="6" Grid.Column="1" Margin="4" BorderBrush="{x:Null}" Background="WhiteSmoke" IsReadOnly="True"/>

				<!-- Uploaded by -->
				<Label Grid.Row="7" Grid.Column="0" Content="Uploaded by :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalUsername" Grid.Row="7" Grid.Column="1" Margin="4" IsReadOnly="True" BorderBrush="{x:Null}" Background="WhiteSmoke" />

				<!-- Date Uploaded -->
				<Label Grid.Row="8" Grid.Column="0" Content="Date Uploaded :" HorizontalAlignment="Right" VerticalAlignment="Center"/>
				<TextBox x:Name="txt_UploadFinalDate" Grid.Row="8" Grid.Column="1" Margin="4" IsReadOnly="True" BorderBrush="{x:Null}" Background="WhiteSmoke"/>
			</Grid>
		</Border>

		<!-- Buttons -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,20">
			<Button Content="Cancel" Click="Cancel_Click" Height="33" Width="90"/>
			<Button Content="Upload" Background="#3F72AF" Foreground="White"
                    Click="Upload_Click" Height="33" Width="100" Margin="12,0,0,0"/>
		</StackPanel>
	</Grid>
</Window>
