<Window x:Class="NBI_Login.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:data="clr-namespace:CFMS_WPF.Data"
        Title="NBI CFM Login"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#E6E1E7">

	<Grid Margin="20">
		<StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="20,20,20,20">

			<!-- LOGO -->
			<Image Source="\Images\NBI WEVRO LOGO 2026.png"
                   Width="240"
                   Height="240"
                   Margin="0,0,0,15"
                   HorizontalAlignment="Center"/>

			<!-- TITLE -->
			<TextBlock Text="National Bureau of Investigation"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>
			<TextBlock Text="Western Visayas Regional Office"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,0"/>
			<TextBlock Text="Case File Management System"
                       FontSize="24"
                       FontWeight="DemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

			<!-- USERNAME -->
			<Border Background="#F2F2F2"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,0,15">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- User Icon -->
					<TextBlock Text="👤"
                               VerticalAlignment="Center"
                               Margin="5,0,10,0"/>

					<!-- Username TextBox -->
					<TextBox x:Name="login_UsernameBox"
                             Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="16"
                             VerticalContentAlignment="Center" TextChanged="login_UsernameBox_TextChanged"
                             KeyDown="UsernameBox_KeyDown"/>


					<!-- Empty column to match password layout -->
					<Border Grid.Column="2"
                            Width="35"
                            Background="Transparent"/>
				</Grid>

			</Border>

			<!-- PASSWORD -->
			<Border Background="#F2F2F2"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,0,25">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Lock Icon -->
					<TextBlock Text="🔒"
                               VerticalAlignment="Center"
                               Margin="5,0,10,0"/>

					<!-- PasswordBox -->
					<PasswordBox x:Name="login_PasswordBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="16"
                                 VerticalContentAlignment="Center"
                                 KeyDown="PasswordBox_KeyDown"/>

					<!-- Visible Password -->
					<TextBox x:Name="VisiblePasswordBox"
                             Grid.Column="1"
                             Visibility="Collapsed"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="16"
                             VerticalContentAlignment="Center"
                             KeyDown="PasswordBox_KeyDown"/>

					<!-- Eye Button -->
					<Button x:Name="EyeButton"
                            Grid.Column="2"
                            Width="35"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="TogglePassword_Click">

						<Path x:Name="EyeIcon"
                              Width="18"
                              Height="18"
                              Stretch="Uniform"
                              Fill="#4B5563"
                              Data="M1 8C1 8 4 3 8 3s7 5 7 5-3 5-7 5-7-5-7-5z
                                    M8 6a2 2 0 1 1 0 4a2 2 0 0 1 0-4z"/>
					</Button>

				</Grid>
			</Border>

			<!-- LOGIN BUTTON -->
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="btn_Login" Content="Log in"
                        Width="150"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#0A1F5E"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,30,0"
                        Click="Login_Click">
                        
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border Background="{TemplateBinding Background}" CornerRadius="10">
								<ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
							</Border>
						</ControlTemplate>
					</Button.Template>
				</Button>

				<Button x:Name="btn_AddProfile" Content="Add Profile"
                        Width="150"
                        Height="45"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#4E73A8"
                        Foreground="White"
                        BorderThickness="0"
                        Click="btn_AddProfile_Click" RenderTransformOrigin="1.467,-0.081">
					<Button.Template>
						<ControlTemplate TargetType="{x:Type Button}">
							<Border Background="{TemplateBinding Background}" CornerRadius="10">
								<ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
							</Border>
						</ControlTemplate>
					</Button.Template>
				</Button>
			</StackPanel>

		</StackPanel>

		<TextBlock VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Margin="0,0,15,10"
                        FontSize="14"
                        IsHitTestVisible="False"
                        Text="{Binding NowPlusTen}" />

		<TextBlock VerticalAlignment="Bottom"
                   HorizontalAlignment="Left"
                   Margin="0,0,15,10"
                   FontSize="14"
                   IsHitTestVisible="False"
                   ><Run Text="Version 1.0.0."/><Run Language="en-ph" Text="2"/></TextBlock>


	</Grid>
</Window>