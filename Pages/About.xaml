<Page x:Class="CFMS_WPF.Pages.PopUp_Windows.About_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CFMS_WPF.Pages.PopUp_Windows"
	  xmlns:data="clr-namespace:CFMS_WPF.Data"
      mc:Ignorable="d" 
      Background="White"
      Title="About_Page">

    <Grid Margin="20">
		<StackPanel>
			<StackPanel Orientation="Horizontal" Margin="0,0,0,20">
				<Image Source="\Images\NBI WEVRO LOGO 2026.png"
                           Width="70"
                           Height="70"
                           Margin="0,0,15,0"/>

				<TextBlock Text="About"
                               FontSize="32"
                               FontWeight="DemiBold"
                               VerticalAlignment="Center"/>
			</StackPanel>
			<StackPanel Margin="0,0,0,10">
				<TextBlock FontSize="18" FontWeight="DemiBold" Text="This is the official National Bureau of Investigation (NBI ) Western Visayas Regional Office Case File Management System."/>
				<TextBlock FontSize="18" Text="Developed by NBI interns, staff, and faculty, this system serves as the central platform for the secure organization, encoding, and management of scanned case files."/>
				<TextBlock FontSize="18" Text="Its primary purpose is to ensure that all case-related documents are systematically cataloged, easily retrievable, and maintained with the highest standards of confidentiality and integrity."/>
				<TextBlock FontSize="18" Text="The system is designed to support NBI employees in their investigative and administrative duties, providing them with a reliable tool to access, review, and utilize case information at their discretion."/>
				
			</StackPanel>

			<StackPanel Margin="0,0,0,10" Orientation="Horizontal">
				<TextBlock FontSize="18" FontWeight="DemiBold" Text="Supervisor : "/>
				<TextBlock FontSize="18" Text="Renzo John S. Ganancial" Margin="5,0,0,0"/>
			</StackPanel>

			<StackPanel Margin="0,0,0,10">
				<TextBlock FontSize="18" FontWeight="DemiBold" Text="Developers : "/>
				<TextBlock FontSize="18" Text="Ryan Dioven V. Aguilar" Margin="72,0,0,0"/>
				<TextBlock FontSize="18" Text="Leandro Jose B. Erenta" Margin="72,0,0,0"/>
				<TextBlock FontSize="18" Text="John Achilles V. Colon" Margin="72,0,0,0"/>
				<TextBlock FontSize="18" Text="Ed Carlo Nile L. Parcellano" Margin="72,0,0,0"/>
				<TextBlock FontSize="18" Text="Julianne Ruth C. Pamplona" Margin="72,0,0,0"/>
				<TextBlock FontSize="18" Text="Shereene P. Dasal" Margin="72,0,0,0"/>
			</StackPanel>

			<StackPanel>
				<TextBlock Text="{x:Static data:AppVersionHelper.Version}"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Page>
