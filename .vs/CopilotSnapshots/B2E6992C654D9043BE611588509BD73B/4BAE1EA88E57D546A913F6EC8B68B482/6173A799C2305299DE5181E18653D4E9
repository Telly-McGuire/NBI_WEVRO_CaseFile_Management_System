		private bool _isUpdatingEditNature = false;

		private void txt_EditNature_Changed(object sender, TextChangedEventArgs e)
		{
			if (_isUpdatingEditNature) return;

			var textBox = sender as TextBox;
			if (textBox == null) return;

			string upper = textBox.Text.ToUpper();

			if (textBox.Text != upper)
			{
				_isUpdatingEditNature = true;

				int caretIndex = textBox.CaretIndex;
				textBox.Text = upper;
				textBox.CaretIndex = caretIndex;

				_isUpdatingEditNature = false;
			}
		}
