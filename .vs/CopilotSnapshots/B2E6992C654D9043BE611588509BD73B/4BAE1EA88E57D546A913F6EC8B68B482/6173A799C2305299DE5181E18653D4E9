		private void BuildFileName()
		{
			string prefix = string.Empty;

			// Case type prefix
			if (Edit_CaseTypeComboBox.SelectedItem is CaseType selectedType)
			{
				switch (selectedType.type_name)
				{
					case "Crime": prefix = "C"; break;
					case "Service": prefix = "S"; break;
					case "Misc": prefix = "M"; break;
				}
			}

			// Year (last 2 digits)
			string year = string.Empty;
			if (int.TryParse(txt_EditYear.Text.Trim(), out int yearValue))
			{
				year = (yearValue % 100).ToString("D2");
			}

			string caseNo = txt_EditCaseNo.Text.Trim();
			string complainant = txt_EditComplainants.Text.Trim().Replace(" ", "_");
			string agent = Edit_AgentNameComboBox.SelectedItem is AgentData a ? a.agentlastName : string.Empty;
			string status = Edit_StatusComboBox.SelectedItem is CaseStatus s ? s.status_name : string.Empty;

			// Build filename parts
			var parts = new List<string>();
			if (!string.IsNullOrEmpty(prefix)) parts.Add(prefix);
			if (!string.IsNullOrEmpty(year)) parts.Add(year);
			if (!string.IsNullOrEmpty(caseNo)) parts.Add(caseNo);
			if (!string.IsNullOrEmpty(complainant)) parts.Add(complainant);
			if (Edit_MultipleComplainantsCheckBox.IsChecked == true)
			{
				if (!parts.Contains("et.al."))
					parts.Add("et.al.");
			}
			else
			{
				parts.Remove("et.al.");
			}
			if (!string.IsNullOrEmpty(agent)) parts.Add(agent);
			if (!string.IsNullOrEmpty(status)) parts.Add(status);

			// Join with dashes
			txt_EditFileName.Text = string.Join("-", parts);
		}


		private void Save_Click(object sender, RoutedEventArgs e)
		{
			try
			{
             con.Open();

				// Update case_data table using parameters (including case_type)
				string sqlCase = @"UPDATE case_data SET
					case_type = @caseType,
					case_year = @caseYear,
					case_number = @caseNumber,
					case_subject = @caseSubject,
					case_nature = @caseNature,
					complainant = @complainant,
					agent_id = @agentId,
					status = @status
				WHERE case_id = @caseId";

				cmd = new MySqlCommand(sqlCase, con);
				cmd.Parameters.AddWithValue("@caseType", (Edit_CaseTypeComboBox.SelectedItem as CaseType)?.type_ID ?? 0);
				cmd.Parameters.AddWithValue("@caseYear", txt_EditYear.Text.Trim());
				cmd.Parameters.AddWithValue("@caseNumber", txt_EditCaseNo.Text.Trim());
				cmd.Parameters.AddWithValue("@caseSubject", txt_EditSubject.Text.Trim());
				cmd.Parameters.AddWithValue("@caseNature", txt_EditNature.Text.Trim());
				cmd.Parameters.AddWithValue("@complainant", txt_EditComplainants.Text.Trim());
				cmd.Parameters.AddWithValue("@agentId", (Edit_AgentNameComboBox.SelectedItem as AgentData)?.agentID ?? 0);
				cmd.Parameters.AddWithValue("@status", (Edit_StatusComboBox.SelectedItem as CaseStatus)?.status_id ?? 0);
				cmd.Parameters.AddWithValue("@caseId", _caseId);

				cmd.ExecuteNonQuery();

				// Update case_documents table (file name + uploader + date) using parameters
				string sqlDoc = @"UPDATE case_documents SET
					file_name = @fileName,
					uploaded_by = (SELECT user_id FROM users WHERE username = @username),
					uploaded_at = @uploadedAt
				WHERE case_id = @caseId";

				cmd = new MySqlCommand(sqlDoc, con);
				cmd.Parameters.AddWithValue("@fileName", txt_EditFileName.Text.Trim());
				cmd.Parameters.AddWithValue("@username", UsernameText.Text.Trim());
				cmd.Parameters.AddWithValue("@uploadedAt", DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
				cmd.Parameters.AddWithValue("@caseId", _caseId);

				cmd.ExecuteNonQuery();

				MessageBox.Show("Case updated successfully!",
								"Success",
								MessageBoxButton.OK,
								MessageBoxImage.Information);

				this.Close();
			}
			catch (Exception ex)
			{
				MessageBox.Show("Error saving case:\n" + ex.Message,
								"Database Error",
								MessageBoxButton.OK,
								MessageBoxImage.Error);
			}
			finally
			{
				con.Close();
			}
		}



